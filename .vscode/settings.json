{
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "[yaml]": {
    "editor.defaultEncoding": "utf-8",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultEncoding": "utf-8",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.wordWrap": "on"
  },
  "[shell]": {
    "editor.defaultEncoding": "utf-8",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.defaultEncoding": "utf-8",
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[dockerfile]": {
    "editor.defaultEncoding": "utf-8",
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "shellcheck.enable": true,
  "shellcheck.run": "onSave"
}
